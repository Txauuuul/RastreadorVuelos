# ==========================================
# CONFIGURACIÓN - Flight Tracker
# ==========================================
# Copia este archivo a .env y rellena tus datos
# NUNCA commits .env a git (contiene secretos)

# ==========================================
# APIS DE BÚSQUEDA DE VUELOS
# ==========================================

# Amadeus API (REQUERIDO)
# Obtén aquí: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=tu_client_id_aqui
AMADEUS_CLIENT_SECRET=tu_client_secret_aqui

# Skyscanner API (OPCIONAL - para comparar precios)
# Obtén aquí: https://www.skyscanner.com/partner-api/
# O en RapidAPI: https://rapidapi.com/skyscanner/api/skyscanner-flight-search
SKYSCANNER_API_KEY=sk_live_DUMMY

# Kiwi.com API (OPCIONAL - generalmente más barato que Amadeus)
# Obtén aquí: https://docs.kiwi.com/
KIWI_API_KEY=DUMMY

# Google Flights API (OPCIONAL - en desarrollo)
GOOGLE_FLIGHTS_API_KEY=DUMMY

# ==========================================
# BASE DE DATOS
# ==========================================

# PostgreSQL en Render (OPCIONAL - fallback a SQLite si está vacío)
# Si usas Render: postgresql://user:pass@host:port/dbname
DATABASE_URL=

# SQLite local (se usa automáticamente si DATABASE_URL está vacío)
DB_PATH=data/vuelos.db

# ==========================================
# TELEGRAM BOT
# ==========================================

# Token del bot de Telegram (REQUERIDO)
# Obtén aquí: @BotFather en Telegram
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui

# Chat ID donde recibir alertas (REQUERIDO)
# Obtén aquí: @userinfobot en Telegram
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ==========================================
# CONFIGURACIÓN DE ALERTAS
# ==========================================

# Precio mínimo absoluto en EUR
MIN_PRICE_THRESHOLD=50.0

# Porcentaje de reducción vs media histórica (%)
PRICE_REDUCTION_PERCENTAGE=15.0

# ==========================================
# LOGGING y DESARROLLO
# ==========================================

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Archivo de logs
LOG_FILE=logs/flight_tracker.log

# Modo debug (True/False)
DEBUG=False
